# Copy this file to .env and fill in real values before running the server.

# Any long random string — used to sign login sessions (JWT).
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=9ef180c54938be97ba3b02067909bfe2226738c1df2975f892851473626ccba6e27c364caf15e1794aa69a0d5440c928

# Port the API server listens on.
PORT=4000

# The URL your frontend is served from, for CORS. In production this is
# your deployed frontend URL (e.g. https://lexora.yourdomain.com).
# In dev, this matches Vite's default port.
CLIENT_ORIGIN=http://localhost:5173

# Set to "production" when deploying — enables secure (HTTPS-only) cookies.
NODE_ENV=development
